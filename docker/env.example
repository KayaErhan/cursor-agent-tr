# docker/compose.yml icin kopyalayin: docker/.env (veya proje kokunden docker compose kullaniyorsaniz uygun yere)
# Windows PowerShell: Copy-Item docker\env.example docker\.env

POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_PORT=5432

# Sadece --profile tools ile pgadmin baslatildiginda gerekli
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
